{
  "name": "svelte-streamdown",
  "version": "0.0.1",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css",
    "README.md"
  ],
  "homepage": "https://github.com/undivisible/svelte-streamdown",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/undivisible/svelte-streamdown.git",
    "directory": "packages/svelte-streamdown"
  },
  "scripts": {
    "prebuild": "bun run --cwd ../remend build",
    "build": "svelte-package",
    "check-types": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "bun run check-types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "author": "Max Carter",
  "license": "MPL-2.0",
  "description": "A Svelte markdown renderer designed for AI-powered streaming.",
  "dependencies": {
    "hast-util-to-html": "^9.0.5",
    "html-url-attributes": "^3.0.1",
    "marked": "^17.0.1",
    "rehype-harden": "^1.1.8",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-cjk-friendly": "^2.3.1",
    "remark-cjk-friendly-gfm-strikethrough": "^2.3.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remend": "workspace:*",
    "shiki": "^4.2.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/hast": "^3.0.4",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}

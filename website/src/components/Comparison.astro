---
// Three-way comparison table: us vs beynar vs Vercel upstream
---

<section class="comparison">
  <h2>How we compare</h2>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Feature</th>
          <th class="us">svelte-streamdown<br><span class="tag">this</span></th>
          <th>beynar/svelte-streamdown<br><span class="tag">npm</span></th>
          <th>vercel/streamdown<br><span class="tag">React</span></th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Framework</td>
          <td class="us">Svelte 5</td>
          <td>Svelte 5</td>
          <td>React 18+</td>
        </tr>
        <tr>
          <td>Lexing engine</td>
          <td class="us">unified / remark</td>
          <td>marked</td>
          <td>unified / remark</td>
        </tr>
        <tr>
          <td>Code highlighting</td>
          <td class="us">rehype plugin (pipeline)</td>
          <td>component-level (shiki/core)</td>
          <td>plugin (@streamdown/code)</td>
        </tr>
        <tr>
          <td>Code block header</td>
          <td class="us">Copy + language</td>
          <td>Copy + download + language</td>
          <td>Copy + download + language</td>
        </tr>
        <tr>
          <td>Mermaid</td>
          <td class="us">Opt-in (auto-detect)</td>
          <td>Opt-in (component import)</td>
          <td>Plugin (@streamdown/mermaid)</td>
        </tr>
        <tr>
          <td>Math (KaTeX)</td>
          <td class="us">remark-math + rehype-katex</td>
          <td>Opt-in (component import)</td>
          <td>Plugin (@streamdown/math)</td>
        </tr>
        <tr>
          <td>Animations</td>
          <td class="us">Fade, blur, slide</td>
          <td>Blur, fade, slide</td>
          <td>Blur, fade, slide</td>
        </tr>
        <tr>
          <td>Dual-theme (light/dark)</td>
          <td class="us">CSS custom properties</td>
          <td>Inline color per token</td>
          <td>CSS custom properties</td>
        </tr>
        <tr>
          <td>Security</td>
          <td class="us">rehype-harden</td>
          <td>None</td>
          <td>rehype-harden</td>
        </tr>
        <tr>
          <td>CSS approach</td>
          <td class="us">Framework-agnostic</td>
          <td>Tailwind required</td>
          <td>Tailwind required</td>
        </tr>
        <tr>
          <td>Streaming repair</td>
          <td class="us">remend</td>
          <td>remend</td>
          <td>remend</td>
        </tr>
        <tr>
          <td>License</td>
          <td class="us">MPL-2.0</td>
          <td>MIT</td>
          <td>Apache-2.0</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p class="note">
    Install from git:
    <code>npm install github:undivisible/svelte-streamdown</code>
  </p>
</section>

<style>
  .comparison {
    width: 100%;
    max-width: 1200px;
    margin-top: 3rem;
  }

  h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    text-align: center;
    color: var(--text);
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  thead {
    background: var(--bg-raised);
  }

  th {
    padding: 0.625rem 0.75rem;
    text-align: left;
    font-weight: 500;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  th.us {
    color: var(--text);
    background: rgba(255, 255, 255, 0.03);
  }

  .tag {
    display: inline-block;
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.1em 0.35em;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-dim);
    margin-left: 0.25rem;
    vertical-align: middle;
  }

  td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
  }

  td.us {
    color: var(--text);
    background: rgba(255, 255, 255, 0.03);
    font-weight: 500;
  }

  tr:last-child td {
    border-bottom: none;
  }

  .note {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .note code {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: var(--text-muted);
  }
</style>
